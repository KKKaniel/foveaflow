{
  "name": "foveaflow",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build && bun run csp:headers",
    "csp:headers": "bun scripts/apply-csp.ts",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "lint": "astro check",
    "check": "astro check",
    "check:tools": "tsc --noEmit -p tsconfig.tools.json",
    "test": "bun test --pass-with-no-tests",
    "test:smoke": "playwright test --pass-with-no-tests",
    "audit": "bun audit",
    "verify": "bun run format && bun run format:check && bun run check && bun run check:tools && bun run tailwind:diagnostics && bun run test && bun run test:smoke && bun run audit",
    "prepush": "bun run verify",
    "tailwind:diagnostics": "bun scripts/tailwind-canonical-classes.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:svelte": "prettier --write \"src/**/*.{svelte,astro,ts,css}\"",
    "generate-types": "wrangler types",
    "deploy": "bun run verify && bun run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^8.1.2",
    "@lucide/svelte": "^1.18.0",
    "@tailwindcss/vite": "4.3.0",
    "astro": "^6.4.6",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "1.1.0",
    "prettier": "^3.8.4",
    "svelte": "^5.56.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "^1.61.0",
    "@types/bun": "^1.3.14",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.2",
    "shadcn-svelte": "^1.3.0",
    "vite": "^7.3.5",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "fast-uri": "^3.1.2",
    "ws": "^8.21.0",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0"
  }
}
