{
  "name": "foveaflow",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build && bun run csp:headers",
    "csp:headers": "bun scripts/apply-csp.ts",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "lint": "astro check",
    "check": "astro check",
    "test": "bun test --pass-with-no-tests",
    "audit": "bun audit",
    "verify": "bun run check && bun run test && bun run audit",
    "tailwind:diagnostics": "bun scripts/tailwind-canonical-classes.ts",
    "tailwind:fix": "bun scripts/tailwind-canonical-classes.ts --write",
    "format": "prettier --write .",
    "format:svelte": "prettier --write \"src/**/*.{svelte,astro,ts,css}\"",
    "generate-types": "wrangler types",
    "deploy": "bun run verify && bun run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^8.1.1",
    "@lucide/svelte": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.3",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "1.1.0",
    "prettier": "^3.8.3",
    "svelte": "^5.55.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@types/bun": "^1.3.13",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "shadcn-svelte": "^1.2.7",
    "vite": "^7.3.3",
    "wrangler": "^4.90.0"
  },
  "overrides": {
    "yaml": "^2.8.3",
    "fast-uri": "^3.1.2"
  }
}
