---
import "../styles/global.css";
import SeoHead from "../lib/components/SeoHead.astro";
import TrainerApp from "../lib/components/TrainerApp.svelte";
import { faqItems } from "../lib/content/page-copy";
import { siteMetadata } from "../lib/content/site";
import {
  referenceLinks,
  safetyNote,
  trainingModeNotes,
} from "../lib/content/training";
import { buildStructuredData, getSiteOrigin } from "../lib/seo";

const siteOrigin = getSiteOrigin(Astro.site);
const structuredData = buildStructuredData(siteOrigin);
---

<html lang="en">
  <head>
    <SeoHead
      title={siteMetadata.title}
      description={siteMetadata.description}
      canonicalPath="/"
      {structuredData}
    />
  </head>
  <body>
    <TrainerApp client:load />
    <noscript>
      <main class="noscript-shell">
        <section class="noscript-panel">
          <p class="noscript-kicker">Free browser tool</p>
          <p class="noscript-title">{siteMetadata.title}</p>
          <p>{siteMetadata.shortDescription}</p>
          <p>
            Eye Trainer needs JavaScript to run the moving target canvas. With
            JavaScript on, you can set the speed, target size, target shape,
            color, trail, viewing distance, and screen scale.
          </p>
          <h2>What you can practice</h2>
          <ul>
            {
              trainingModeNotes.map((trainingModeNote) => (
                <li>
                  <strong>{trainingModeNote.title}:</strong>{" "}
                  {trainingModeNote.body}
                </li>
              ))
            }
          </ul>
          <h2>Safety</h2>
          <p>{safetyNote}</p>
          <section data-nosnippet>
            <h2>Common questions</h2>
            {
              faqItems.map((faqItem) => (
                <article>
                  <h3>{faqItem.question}</h3>
                  <p>{faqItem.answer}</p>
                </article>
              ))
            }
          </section>
          <h2>Background reading</h2>
          <ul>
            {
              referenceLinks.map((referenceLink) => (
                <li>
                  <a href={referenceLink.url}>{referenceLink.label}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </main>
    </noscript>
  </body>
</html>
