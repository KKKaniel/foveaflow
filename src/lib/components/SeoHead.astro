---
import { generateSetInitialModeExpression } from "mode-watcher";
import { siteMetadata } from "../content/site";
import { absoluteUrl, getSiteOrigin } from "../seo";
import ThemeFavicon from "./ThemeFavicon.astro";

type OpenGraphType = "website" | "article";

interface Props {
  title: string;
  description: string;
  canonicalPath: `/${string}`;
  structuredData?: unknown;
  ogType?: OpenGraphType;
  robots?: string;
}

const {
  title,
  description,
  canonicalPath,
  structuredData,
  ogType = "website",
  robots = "index,follow,max-image-preview:large",
} = Astro.props;

const initialModeExpression = generateSetInitialModeExpression({
  defaultMode: "system",
});
const siteOrigin = getSiteOrigin(Astro.site);
const canonicalUrl = absoluteUrl(canonicalPath, siteOrigin);
const ogImageUrl = absoluteUrl(siteMetadata.imagePath, siteOrigin);
const structuredDataJson =
  structuredData === undefined ? "" : JSON.stringify(structuredData);
---

<meta charset="utf-8" />
<script is:inline set:html={initialModeExpression} />
<ThemeFavicon />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />
<link
  rel="alternate"
  type="application/xml"
  href="/sitemap.xml"
  title="Sitemap"
/>
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<meta name="robots" content={robots} />
<meta name="date" content={siteMetadata.lastUpdated} />
<meta name="last-modified" content={siteMetadata.lastUpdated} />
<meta name="DC.date.modified" content={siteMetadata.lastUpdated} />
<meta name="application-name" content={siteMetadata.name} />
<meta name="apple-mobile-web-app-title" content={siteMetadata.name} />
<meta name="theme-color" content="#95E217" />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={siteMetadata.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:updated_time" content={siteMetadata.lastUpdated} />
<meta
  property="og:image:alt"
  content="Eye Trainer canvas with a moving practice target"
/>
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{
  ogType === "article" && (
    <meta property="article:modified_time" content={siteMetadata.lastUpdated} />
  )
}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta
  name="twitter:image:alt"
  content="Eye Trainer canvas with a moving practice target"
/>
{
  structuredDataJson && (
    <script
      is:inline
      type="application/ld+json"
      set:html={structuredDataJson}
    />
  )
}
<title>{title}</title>
